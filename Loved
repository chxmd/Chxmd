<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>For Laila</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Poppins&display=swap');

        body {
            margin: 0;
            height: 100vh;
            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Poppins', sans-serif;
            color: #4a2c2a;
        }
        .container {
            background: #fff0f4cc;
            padding: 2.5rem 3rem;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(255, 105, 180, 0.3);
            text-align: center;
            max-width: 400px;
        }
        h1 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.8rem;
            margin-bottom: 1.8rem;
        }
        .buttons {
            display: flex;
            justify-content: space-around;
            gap: 1rem;
        }
        button {
            cursor: pointer;
            border: none;
            outline: none;
            font-size: 1rem;
            font-weight: 600;
            padding: 0.65rem 1.4rem;
            border-radius: 30px;
            transition: all 0.3s ease;
            user-select: none;
        }
        button#yesBtn {
            background: #ff578f;
            color: white;
        }
        button#yesBtn:hover {
            background: #ff3366;
            box-shadow: 0 8px 15px rgba(255, 51, 102, 0.4);
        }
        button#noBtn {
            position: relative;
            background: #bbb;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>I love u Laila,<br>do you love me too?</h1>
        <div class="buttons" id="button-area">
            <button id="yesBtn">Yess, I am really love u too</button>
            <button id="noBtn">No</button>
        </div>
    </div>

    <script>
        const noBtn = document.getElementById('noBtn');
        const buttonArea = document.getElementById('button-area');

        const moveNoButton = () => {
            const areaRect = buttonArea.getBoundingClientRect();
            const noRect = noBtn.getBoundingClientRect();

            const maxX = areaRect.width - noRect.width;
            const maxY = areaRect.height - noRect.height;

            const randomX = Math.random() * maxX;
            const randomY = Math.random() * maxY;

            noBtn.style.position = 'absolute';
            noBtn.style.left = randomX + 'px';
            noBtn.style.top = randomY + 'px';
        };

        noBtn.addEventListener('mouseenter', moveNoButton);
        noBtn.addEventListener('mouseover', moveNoButton);
        noBtn.addEventListener('click', (e) => {
            e.preventDefault();
        });

        const yesBtn = document.getElementById('yesBtn');
        yesBtn.addEventListener('click', () => {
            window.location.href = 'surprise.html';
        });
    </script>
</body>
</html>
